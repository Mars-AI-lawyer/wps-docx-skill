{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://codex.local/docx-wps-redline/edit-plan.schema.json",
  "title": "DOCX WPS Redline Edit Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["document_id", "generated_at", "actions"],
  "properties": {
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/action"
      }
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action_id", "action_type", "target", "comment"],
      "properties": {
        "action_id": {
          "type": "string",
          "minLength": 1
        },
        "action_type": {
          "type": "string",
          "enum": [
            "comment_only",
            "replace_sentence",
            "replace_clause",
            "insert_sentence_after",
            "delete_sentence"
          ]
        },
        "target": {
          "$ref": "#/$defs/target"
        },
        "replacement_text": {
          "type": "string"
        },
        "comment": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action_type": {
                "const": "replace_sentence"
              }
            }
          },
          "then": {
            "required": ["replacement_text"],
            "properties": {
              "replacement_text": {
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_type": {
                "const": "replace_clause"
              }
            }
          },
          "then": {
            "required": ["replacement_text"],
            "properties": {
              "replacement_text": {
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_type": {
                "const": "insert_sentence_after"
              }
            }
          },
          "then": {
            "required": ["replacement_text"],
            "properties": {
              "replacement_text": {
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "container_type",
        "paragraph_index",
        "table_path",
        "target_text",
        "context_before",
        "context_after",
        "normalized_text_hash"
      ],
      "properties": {
        "container_type": {
          "type": "string",
          "enum": ["paragraph", "table_cell", "paragraph_range"]
        },
        "paragraph_index": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "paragraph_range": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": ["start_paragraph_index", "end_paragraph_index"],
          "properties": {
            "start_paragraph_index": {
              "type": "integer",
              "minimum": 0
            },
            "end_paragraph_index": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "table_path": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "required": [
            "table_index",
            "row_index",
            "cell_index",
            "paragraph_index_in_cell"
          ],
          "properties": {
            "table_index": {
              "type": "integer",
              "minimum": 0
            },
            "row_index": {
              "type": "integer",
              "minimum": 0
            },
            "cell_index": {
              "type": "integer",
              "minimum": 0
            },
            "paragraph_index_in_cell": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "target_text": {
          "type": "string",
          "minLength": 1
        },
        "context_before": {
          "type": "string"
        },
        "context_after": {
          "type": "string"
        },
        "normalized_text_hash": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "container_type": {
                "const": "paragraph_range"
              }
            }
          },
          "then": {
            "properties": {
              "paragraph_index": {
                "type": "null"
              },
              "table_path": {
                "type": "null"
              }
            }
          }
        }
      ]
    }
  }
}
